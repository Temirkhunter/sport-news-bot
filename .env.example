# Telegram (чтение через Telethon)
# Получить на https://my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=sport_bot

# Telegram (публикация через Bot API)
TG_BOT_TOKEN=
TG_TARGET_CHANNEL=@your_channel

# VK
# Получить на https://vkhost.github.io (права: wall, offline)
VK_ACCESS_TOKEN=
VK_API_VERSION=5.199

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat

# Images (опциональны; Pollinations работает без ключа)
TOGETHER_API_KEY=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Schedule
CHECK_INTERVAL_MINUTES=20
POST_DELAY_SECONDS=30
MAX_POSTS_PER_RUN=3

# Behavior
DRY_RUN=false
ADD_SOURCE_LINK=false
ADMIN_CHAT_ID=
LOG_LEVEL=INFO
